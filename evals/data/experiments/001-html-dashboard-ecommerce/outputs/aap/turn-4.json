{
  "protocol": "aap/0.1",
  "id": "add-recent-activity-section",
  "version": 1,
  "name": "diff",
  "operation": {
    "direction": "output",
    "format": "text/html",
    "tokens_used": null,
    "created_at": null,
    "updated_at": null
  },
  "content": [
    {
      "op": "insert_after",
      "target": {
        "search": null,
        "section": "stats",
        "lines": null,
        "offsets": null,
        "pointer": null
      },
      "content": "\n<aap:section id=\"recent-activity\">\n    <h2>Recent Activity</h2>\n    <div class=\"card\">\n        <ul style=\"list-style: none; padding: 0;\">\n            <script>\n                const activities = [\"User logged in\", \"Product updated\", \"Order placed\", \"New customer signed up\", \"System update completed\"];\n                for(let i=1; i<=10; i++) {\n                    document.write(`<li style=\"padding: 8px 0; border-bottom: 1px solid #eee;\"><strong>${activities[i%5]}</strong> - ${i} minutes ago</li>`);\n                }\n            </script>\n        </ul>\n    </div>\n</aap:section>\n"
    }
  ]
}