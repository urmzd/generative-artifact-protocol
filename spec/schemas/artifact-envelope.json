{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aap.dev/schemas/artifact-envelope.json",
  "title": "Artifact Envelope",
  "description": "Universal message format for the Agent-Artifact Protocol (AAP). Every interaction — artifact content, diffs, projections, edit intents, results, audit entries — is an envelope.",
  "type": "object",
  "required": ["protocol", "id", "version", "name", "operation", "content"],
  "properties": {
    "protocol": {
      "type": "string",
      "const": "aap/1.0",
      "description": "Protocol identifier and version"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique artifact identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonically increasing version number. For non-full operations, the apply engine validates stored_version == version - 1"
    },
    "name": {
      "type": "string",
      "enum": ["full", "diff", "section", "template", "composite", "manifest", "handle", "projection", "intent", "result", "audit"],
      "description": "Operation discriminator — determines the shape of content items"
    },
    "operation": {
      "type": "object",
      "required": ["direction"],
      "description": "Metadata about the action",
      "properties": {
        "direction": {
          "type": "string",
          "enum": ["input", "output"],
          "description": "Message direction: input (to the system) or output (from the system)"
        },
        "format": {
          "type": "string",
          "pattern": "^[a-z]+/[a-z0-9.+-]+$",
          "description": "MIME type of the artifact content"
        },
        "encoding": {
          "type": "string",
          "default": "utf-8",
          "description": "Character encoding"
        },
        "content_encoding": {
          "type": "string",
          "enum": ["gzip", "zstd"],
          "description": "Compression applied to content body fields"
        },
        "section_id": {
          "type": "string",
          "description": "Section this result fills (parallel section results)"
        },
        "token_budget": {
          "type": "object",
          "properties": {
            "max_tokens": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum content tokens"
            },
            "priority": {
              "type": "string",
              "enum": ["completeness", "brevity", "fidelity"],
              "description": "Budget priority hint"
            },
            "max_sections": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum sections to regenerate"
            }
          },
          "description": "Token budget constraints"
        },
        "tokens_used": {
          "type": "integer",
          "minimum": 0,
          "description": "Actual content tokens consumed"
        },
        "checksum": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 hash of resolved content"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 creation timestamp"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 update timestamp"
        },
        "state": {
          "type": "string",
          "enum": ["draft", "published", "archived"],
          "description": "Entity lifecycle state"
        },
        "state_changed_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last state transition"
        }
      },
      "additionalProperties": true
    },
    "content": {
      "type": "array",
      "items": { "type": "object" },
      "description": "List of content objects — shape determined by name. Array enables parallel operations in a single envelope."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "name": { "const": "full" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["body"],
              "properties": {
                "body": { "type": "string", "description": "Full artifact content" },
                "sections": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id"],
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "label": { "type": "string" },
                      "start_marker": { "type": "string" },
                      "end_marker": { "type": "string" }
                    }
                  },
                  "description": "Section definitions"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "diff" } } },
      "then": {
        "properties": {
          "content": {
            "items": { "$ref": "diff-operation.json" }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "section" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["id", "content"],
              "properties": {
                "id": { "type": "string", "description": "Section ID to replace" },
                "content": { "type": "string", "description": "New content for this section" }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "template" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["template", "bindings"],
              "properties": {
                "template": { "type": "string", "description": "Template content or registered template ID" },
                "bindings": { "$ref": "template-binding.json", "description": "Slot bindings" }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "composite" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "properties": {
                "ref": { "type": "string", "description": "Reference to artifact or artifact:section" },
                "uri": { "type": "string", "format": "uri", "description": "External URI" },
                "content": { "type": "string", "description": "Inline fallback content" },
                "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$", "description": "Expected content hash" }
              },
              "oneOf": [
                { "required": ["ref"] },
                { "required": ["uri"] },
                { "required": ["content"] }
              ]
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "manifest" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["skeleton", "section_prompts"],
              "properties": {
                "skeleton": { "type": "string", "description": "Static scaffold with section markers" },
                "section_prompts": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "prompt"],
                    "properties": {
                      "id": { "type": "string" },
                      "prompt": { "type": "string" },
                      "dependencies": { "type": "array", "items": { "type": "string" } },
                      "token_budget": { "type": "integer", "minimum": 1 }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "handle" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["sections"],
              "properties": {
                "sections": { "type": "array", "items": { "type": "string" }, "description": "Section IDs present" },
                "token_count": { "type": "integer", "minimum": 0, "description": "Approximate token count" },
                "state": { "type": "string", "enum": ["draft", "published", "archived"] },
                "entity": { "$ref": "entity-metadata.json" }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "projection" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["projection_type", "token_count"],
              "properties": {
                "projection_type": { "type": "string", "enum": ["structure", "content_summary", "change_summary", "statistics", "full_summary"] },
                "token_count": { "type": "integer", "minimum": 0 },
                "sections": { "type": "array", "items": { "type": "object" } },
                "changes": { "type": "array", "items": { "type": "object" } },
                "outline": { "type": "string" },
                "summary": { "type": "string" },
                "statistics": { "type": "object" }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "intent" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["intent"],
              "properties": {
                "intent": { "type": "string", "minLength": 1, "description": "Natural-language description of the desired change" },
                "target_sections": { "type": "array", "items": { "type": "string" } },
                "constraints": {
                  "type": "object",
                  "properties": {
                    "max_tokens": { "type": "integer", "minimum": 1 },
                    "preserve_structure": { "type": "boolean" },
                    "mode_hint": { "type": "string", "enum": ["diff", "section", "template", "full"] },
                    "validation": { "type": "string" }
                  }
                },
                "priority": { "type": "string", "enum": ["completeness", "brevity", "fidelity"] },
                "idempotency_key": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "result" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["status", "mode_used", "changes"],
              "properties": {
                "status": { "type": "string", "enum": ["applied", "rejected", "partial", "conflict"] },
                "mode_used": { "type": "string" },
                "changes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "section_id": { "type": "string" },
                      "description": { "type": "string" }
                    }
                  }
                },
                "tokens_used": { "type": "integer", "minimum": 0 },
                "handle": { "$ref": "#" },
                "rejection_reason": { "type": "string" },
                "conflict_detail": { "type": "string" },
                "checksum": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "audit" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["entry_id", "operation", "actor", "timestamp"],
              "properties": {
                "entry_id": { "type": "string", "minLength": 1 },
                "operation": { "type": "string", "enum": ["create", "read", "summarize", "edit", "state_transition"] },
                "actor": { "type": "string" },
                "timestamp": { "type": "string", "format": "date-time" },
                "version_before": { "type": "integer", "minimum": 1 },
                "version_after": { "type": "integer", "minimum": 1 },
                "detail": { "type": "object" },
                "status": { "type": "string", "enum": ["success", "failure", "partial"] },
                "error": { "type": "string" },
                "tokens_used": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    }
  ]
}
