<profiles>
  <profile>
    <id>dev</id>
    <properties>
      <app.profile>dev</app.profile>
      <spring.jpa.show-sql>true</spring.jpa.show-sql>
      <spring.jpa.hibernate.ddl-auto>update</spring.jpa.hibernate.ddl-auto>
      <logging.level.root>INFO</logging.level.root>
      <server.port>8080</server.port>
    </properties>
  </profile>

  <profile>
    <id>test</id>
    <properties>
      <app.profile>test</app.profile>
      <spring.datasource.url>jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE</spring.datasource.url>
      <spring.datasource.driver-class-name>org.h2.Driver</spring.datasource.driver-class-name>
      <spring.datasource.username>sa</spring.datasource.username>
      <spring.datasource.password></spring.datasource.password>
      <spring.jpa.database-platform>org.hibernate.dialect.H2Dialect</spring.jpa.database-platform>
      <spring.jpa.hibernate.ddl-auto>create-drop</spring.jpa.hibernate.ddl-auto>
      <spring.jpa.show-sql>false</spring.jpa.show-sql>
      <spring.flyway.enabled>false</spring.flyway.enabled>
      <testcontainers.enabled>false</testcontainers.enabled>
      <logging.level.root>WARN</logging.level.root>
      <logging.level.org.springframework>WARN</logging.level.org.springframework>
      <logging.level.org.hibernate>WARN</logging.level.org.hibernate>
      <logging.level.com.zaxxer.hikari>WARN</logging.level.com.zaxxer.hikari>
      <server.port>0</server.port>
    </properties>
  </profile>

  <profile>
    <id>staging</id>
    <properties>
      <app.profile>staging</app.profile>
      <spring.jpa.show-sql>false</spring.jpa.show-sql>
      <spring.jpa.hibernate.ddl-auto>validate</spring.jpa.hibernate.ddl-auto>
      <logging.level.root>INFO</logging.level.root>
      <server.port>8081</server.port>
    </properties>
  </profile>

  <profile>
    <id>production</id>
    <properties>
      <app.profile>production</app.profile>
      <spring.jpa.show-sql>false</spring.jpa.show-sql>
      <spring.jpa.hibernate.ddl-auto>none</spring.jpa.hibernate.ddl-auto>
      <logging.level.root>WARN</logging.level.root>
      <server.port>8080</server.port>
    </properties>
  </profile>
</profiles>